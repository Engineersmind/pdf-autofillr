# ── Required ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Storage: 'local' or 's3' ──────────────────────────────────────────
UPLOAD_DOC_STORAGE=local

# ── Local storage paths ────────────────────────────────────────────────
UPLOAD_DOC_DATA_PATH=./uploaddoc_data
UPLOAD_DOC_CONFIG_PATH=./configs

# ── S3 storage — YOUR OWN BUCKETS ─────────────────────────────────────
STATIC_BUCKET=your-static-configs-bucket
OUTPUT_BUCKET=your-output-bucket
AWS_REGION=us-east-1

# ── PDF Lambda (used by document_upload_managed only) ─────────────────
FILL_PDF_LAMBDA_URL=https://your-lambda-url.com
PDF_API_KEY=your_pdf_api_key

# ── Auth0 (used by document_upload_managed only) ──────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=...
AUTH0_CLIENT_SECRET=...
AUTH0_AUDIENCE=https://your-api-audience

# ── PDF workflow ───────────────────────────────────────────────────────
UPLOAD_DOC_PDF_POLL_INTERVAL=10      # seconds between readiness checks
UPLOAD_DOC_PDF_POLL_TIMEOUT=480      # max seconds to wait for embed ready
UPLOAD_DOC_PDF_MAX_RETRIES=3

# ── Telemetry (opt-in) ─────────────────────────────────────────────────
UPLOAD_DOC_TELEMETRY=false
UPLOAD_DOC_TELEMETRY_MODE=local          # local | self_hosted
UPLOAD_DOC_TELEMETRY_ENDPOINT=https://telemetry.yourcompany.com/events
UPLOAD_DOC_TELEMETRY_API_KEY=your_internal_key
UPLOAD_DOC_TELEMETRY_BATCH_SIZE=10
UPLOAD_DOC_TELEMETRY_FLUSH_INTERVAL=30

# ── Debug ──────────────────────────────────────────────────────────────
UPLOAD_DOC_DEBUG_LOGGING=true
UPLOAD_DOC_LOG_LEVEL=INFO