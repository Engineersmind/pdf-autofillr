# ── Required ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Storage: 'local' or 's3' ─────────────────────────────────
chatbot_STORAGE=local

# ── Local storage paths ──────────────────────────────────────
chatbot_DATA_PATH=./chatbot_data
chatbot_CONFIG_PATH=./configs

# ── S3 storage — YOUR OWN BUCKETS ─────────────────────────────
AWS_OUTPUT_BUCKET=your-output-bucket
AWS_CONFIG_BUCKET=your-config-bucket
AWS_REGION=us-east-1

# ── Chatbot customization ─────────────────────────────────────
chatbot_BOT_NAME=Bot
chatbot_GREETING=Hi! I am here to help you fill out your investment documents.

# ── PDF workflow ──────────────────────────────────────────────
chatbot_PDF_POLL_INTERVAL=10      # seconds between readiness checks
chatbot_PDF_POLL_TIMEOUT=150      # max seconds waiting for prepare
chatbot_PDF_MAX_RETRIES=3

# ── Telemetry (opt-in) ────────────────────────────────────────
chatbot_TELEMETRY=false
chatbot_TELEMETRY_MODE=self_hosted   # local | self_hosted | managed
chatbot_TELEMETRY_ENDPOINT=https://telemetry.chatbot.io
chatbot_SDK_API_KEY=chatbot_tel_...

# ── Rate limiting ─────────────────────────────────────────────
chatbot_RATE_LIMIT_ENABLED=false
chatbot_RATE_LIMIT_STORAGE=local   # local | redis
REDIS_URL=redis://localhost:6379

# ── Debug ─────────────────────────────────────────────────────
chatbot_DEBUG_LOGGING=true
chatbot_LOG_LEVEL=INFO
