# Docker Environment Configuration for Mapper Module
# Copy this file to .env and fill in your values

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================

# Source type: local, aws, azure, gcp
SOURCE_TYPE=local

# ============================================
# LLM CONFIGURATION (Required)
# ============================================

# OpenAI API Key (for gpt-4o, gpt-4-turbo, etc.)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API Key (optional - for Claude models)
ANTHROPIC_API_KEY=

# ============================================
# AWS CONFIGURATION (if SOURCE_TYPE=aws)
# ============================================

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 Configuration
# CACHE_REGISTRY_PATH=s3://your-bucket/cache/hash_registry.json
# OUTPUT_BASE_PATH=s3://your-bucket/pdf-autofiller
# RAG_BUCKET_NAME=your-rag-bucket

# ============================================
# AZURE CONFIGURATION (if SOURCE_TYPE=azure)
# ============================================

AZURE_STORAGE_CONNECTION_STRING=

# Blob Storage Configuration
# CACHE_REGISTRY_PATH=azure://your-container/cache/hash_registry.json
# OUTPUT_BASE_PATH=azure://your-container/pdf-autofiller
# RAG_CONTAINER_NAME=your-rag-container

# ============================================
# GCP CONFIGURATION (if SOURCE_TYPE=gcp)
# ============================================

GOOGLE_CLOUD_PROJECT=
# Path to service account key file (will be mounted into container)
GOOGLE_APPLICATION_CREDENTIALS_FILE=

# Cloud Storage Configuration
# CACHE_REGISTRY_PATH=gs://your-bucket/cache/hash_registry.json
# OUTPUT_BASE_PATH=gs://your-bucket/pdf-autofiller
# RAG_BUCKET_NAME=your-rag-bucket

# ============================================
# NOTIFICATIONS (Optional)
# ============================================

TEAMS_NOTIFICATIONS_ENABLED=false
TEAMS_WEBHOOK_URL=

# ============================================
# PERFORMANCE TUNING
# ============================================

LLM_TIMEOUT=300
RAG_TIMEOUT=180
MAX_CONCURRENT_OPERATIONS=5
API_RETRY_ATTEMPTS=3

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=INFO
EXTRACTOR_DEBUG=false
MAPPER_DEBUG=false

# ============================================
# EXAMPLES
# ============================================

# Example 1: Local Development
# SOURCE_TYPE=local
# OPENAI_API_KEY=sk-...

# Example 2: AWS S3
# SOURCE_TYPE=aws
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# OPENAI_API_KEY=sk-...

# Example 3: Azure Blob Storage
# SOURCE_TYPE=azure
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...
# OPENAI_API_KEY=sk-...

# Example 4: Google Cloud Storage
# SOURCE_TYPE=gcp
# GOOGLE_CLOUD_PROJECT=my-project
# GOOGLE_APPLICATION_CREDENTIALS_FILE=./gcp-key.json
# OPENAI_API_KEY=sk-...
