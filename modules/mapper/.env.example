# =============================================================================
# PDF Mapper Module - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# -----------------------------------------------------------------------------
# Cloud Provider Selection
# -----------------------------------------------------------------------------
# Options: 'aws' | 'azure' | 'gcp' | 'local'
CLOUD_PROVIDER=aws

# -----------------------------------------------------------------------------
# AWS Configuration (when CLOUD_PROVIDER=aws)
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your-pdf-bucket
AWS_S3_PREFIX=pdfs/

# -----------------------------------------------------------------------------
# Azure Configuration (when CLOUD_PROVIDER=azure)
# -----------------------------------------------------------------------------
AZURE_STORAGE_CONNECTION_STRING=your_connection_string
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account
AZURE_STORAGE_CONTAINER=your-container
AZURE_STORAGE_KEY=your_storage_key

# -----------------------------------------------------------------------------
# GCP Configuration (when CLOUD_PROVIDER=gcp)
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=your-project-id
GCP_STORAGE_BUCKET=your-gcs-bucket
GCP_CREDENTIALS_PATH=/path/to/service-account.json
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# -----------------------------------------------------------------------------
# LLM Configuration (LiteLLM - Unified Interface for All Providers)
# -----------------------------------------------------------------------------
# LiteLLM Model Format: {provider}/{model-name}
# Examples:
#   - claude-3-5-sonnet-20241022 (Anthropic Direct)
#   - bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0 (AWS Bedrock)
#   - gpt-4o (OpenAI)
#   - azure/gpt-4 (Azure OpenAI)
#   - vertex_ai/gemini-pro (Google)
#   - ollama/llama2 (Local)

# Default LLM model
LLM_MODEL=gpt-4o

# LLM settings
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# === ANTHROPIC (Direct API) ===
# Best price/performance - Recommended
# Sign up: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# === OPENAI ===
# Sign up: https://platform.openai.com/
OPENAI_API_KEY=your-openai-api-key-here

# === AWS BEDROCK ===
# For AWS-native applications
# Uses the AWS credentials set above
# No additional keys needed if AWS_ACCESS_KEY_ID is set

# === AZURE OPENAI ===
# For Azure-native applications
AZURE_API_KEY=your-azure-api-key
AZURE_API_BASE=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2023-05-15

# === GOOGLE VERTEX AI ===
# Uses GOOGLE_APPLICATION_CREDENTIALS set above
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1

# === LOCAL / OLLAMA ===
# For development/testing without API costs
# Install: https://ollama.ai/
OLLAMA_API_BASE=http://localhost:11434

# === LEGACY LLM CONFIG (DEPRECATED - Use LLM_MODEL instead) ===
# Primary LLM Provider: 'openai' | 'azure_openai' | 'anthropic' | 'bedrock'
LLM_PROVIDER=openai
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-3-opus-20240229

# AWS Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_REGION=us-east-1

# -----------------------------------------------------------------------------
# Embedding Model Configuration
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# -----------------------------------------------------------------------------
# RAG Module Configuration
# -----------------------------------------------------------------------------
RAG_MODULE_ENABLED=true
RAG_API_ENDPOINT=https://your-rag-api-endpoint.com/predict
RAG_API_KEY=your-rag-api-key
RAG_TIMEOUT=30

# -----------------------------------------------------------------------------
# Mapper Configuration
# -----------------------------------------------------------------------------
# Mapper strategy: 'semantic' | 'rag' | 'headers' | 'ensemble'
MAPPER_STRATEGY=ensemble

# Ensemble weights (must sum to 1.0)
ENSEMBLE_SEMANTIC_WEIGHT=0.4
ENSEMBLE_RAG_WEIGHT=0.4
ENSEMBLE_HEADERS_WEIGHT=0.2

# Confidence thresholds
MIN_MAPPING_CONFIDENCE=0.6
HEADER_MATCH_THRESHOLD=0.8

# -----------------------------------------------------------------------------
# Extraction Configuration
# -----------------------------------------------------------------------------
EXTRACTOR_TYPE=detailed_fitz
MAX_PAGES_TO_PROCESS=100
EXTRACT_IMAGES=false

# -----------------------------------------------------------------------------
# Chunking Configuration
# -----------------------------------------------------------------------------
CHUNKER_TYPE=page
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# -----------------------------------------------------------------------------
# Java iText Configuration
# -----------------------------------------------------------------------------
JAVA_HOME=/path/to/java
JAVA_HEAP_SIZE=2g
ITEXT_JAR_PATH=./java_utils/itext.jar

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_OUTPUT=stdout

# -----------------------------------------------------------------------------
# API Configuration (for FastAPI entrypoint)
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------
API_KEY=your-api-key
JWT_SECRET=your-jwt-secret-key
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# -----------------------------------------------------------------------------
# Notifications (Teams/Slack)
# -----------------------------------------------------------------------------
TEAMS_WEBHOOK_URL=https://your-teams-webhook-url
NOTIFICATIONS_ENABLED=true

# -----------------------------------------------------------------------------
# Performance & Limits
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_MB=50
REQUEST_TIMEOUT=300
MAX_CONCURRENT_REQUESTS=10

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_CACHING=true
ENABLE_METRICS=true
ENABLE_TRACING=false
DEBUG_MODE=false

# -----------------------------------------------------------------------------
# Testing & Development
# -----------------------------------------------------------------------------
ENVIRONMENT=development
TEST_MODE=false
MOCK_LLM_RESPONSES=false
