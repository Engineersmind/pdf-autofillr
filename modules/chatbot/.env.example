# ── Required ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Storage: 'local' or 's3' ─────────────────────────────────────────
chatbot_STORAGE=local

# ── Local storage paths ───────────────────────────────────────────────
chatbot_DATA_PATH=./chatbot_data
chatbot_CONFIG_PATH=./configs

# ── S3 storage — only required when chatbot_STORAGE=s3 ───────────────
# The SDK will raise a clear error at startup if these are missing.
AWS_OUTPUT_BUCKET=your-output-bucket
AWS_CONFIG_BUCKET=your-config-bucket
AWS_REGION=us-east-1
# Credentials: provide ONE of the following
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
# OR use a named profile:  AWS_PROFILE=myprofile
# OR use an IAM role (Lambda/ECS inject credentials automatically)

# ── PDF filler ────────────────────────────────────────────────────────
# Controls which PDF filling service is used.
# Values: none | mapper | managed | custom
# Default: none (data-only mode — no PDF filling)
chatbot_PDF_FILLER=none

# Path to the blank PDF to be filled.
# REQUIRED when chatbot_PDF_FILLER != none.
# Local:  chatbot_PDF_PATH=/path/to/blank_form.pdf
# S3:     chatbot_PDF_PATH=s3://your-bucket/blank_form.pdf
chatbot_PDF_PATH=

# ── PDF filler: mapper mode ───────────────────────────────────────────
# Only used when chatbot_PDF_FILLER=mapper
# Point to your running pdf-autofillr mapper API server.
MAPPER_API_URL=http://localhost:8000

# Route prefix used by the mapper server.
# api_server.py (default, recommended) registers routes as /mapper/fill etc.
#   → leave MAPPER_URL_PREFIX as /mapper (the default)
# fastapi_app.py (bare app, no prefix) registers routes as /fill etc.
#   → set MAPPER_URL_PREFIX= (empty string)
MAPPER_URL_PREFIX=/mapper

MAPPER_API_KEY=

# ── PDF filler: managed mode ──────────────────────────────────────────
# Only used when chatbot_PDF_FILLER=managed (private chatbot-managed package)
# The SDK will raise a clear error at startup if any of these are missing.
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://your-api-audience
FILL_PDF_LAMBDA_URL=https://your-pdf-lambda-url.com
PDF_API_KEY=
BACKEND_URL=
AUTH_TOKEN=

# ── PDF workflow timing ───────────────────────────────────────────────
chatbot_PDF_POLL_INTERVAL=10      # seconds between readiness checks
chatbot_PDF_POLL_TIMEOUT=150      # max seconds waiting for prepare
chatbot_PDF_MAX_RETRIES=3

# ── Chatbot customisation ─────────────────────────────────────────────
chatbot_BOT_NAME=Bot
chatbot_GREETING=Hi! I am here to help you fill out your investment documents.

# ── Telemetry (opt-in) ────────────────────────────────────────────────
# Values: local | self_hosted | managed
# local:       send to your own local telemetry server (set ENDPOINT below)
# self_hosted: send to your own hosted endpoint
# managed:     send to chatbot-managed service (TBD)
chatbot_TELEMETRY=false
chatbot_TELEMETRY_MODE=local
chatbot_TELEMETRY_ENDPOINT=http://localhost:9000/events
chatbot_SDK_API_KEY=chatbot_tel_...

# ── Rate limiting ─────────────────────────────────────────────────────
chatbot_RATE_LIMIT_ENABLED=false
chatbot_RATE_LIMIT_STORAGE=local   # local | redis
REDIS_URL=redis://localhost:6379

# ── Debug ─────────────────────────────────────────────────────────────
chatbot_DEBUG_LOGGING=true
chatbot_LOG_LEVEL=INFO
